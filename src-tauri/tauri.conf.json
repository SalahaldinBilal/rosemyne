{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rosemyne",
  "version": "0.1.3",
  "identifier": "com.rosemyne.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Rosemyne",
        "width": 1040,
        "height": 700,
        "minWidth": 700,
        "minHeight": 480,
        "theme": "Dark",
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' http://rosemyne-photo.localhost; media-src 'self' http://rosemyne-photo.localhost; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://rosemyne.won.fyi/updater/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM0NkJFMTNCMDYzMzg5NkMKUldSc2lUTUdPK0ZyTkN3aXMwd052ZVpFc2x5TnUvdGlkZGJ4d2dVSk9Va096VGF3NmhITU82WUcK"
    }
  }
}